{
  "name": "figma-development",
  "version": "1.0.0",
  "description": "互動式 CLI，透過 npx 從 GitHub 安裝這個 repo 提供的 Claude Code Figma skills；同時提供 mui-ui 元件庫。",
  "bin": {
    "figma-development": "bin/cli.js"
  },
  "main": "dist/mui-ui.cjs.js",
  "module": "dist/mui-ui.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mui-ui.es.js",
      "require": "./dist/mui-ui.cjs.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "bin",
    ".claude/skills",
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node bin/cli.js --list",
    "build": "tsc -p tsconfig.build.json && vite build",
    "dev": "vite build --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willy874/figma-development.git"
  },
  "homepage": "https://github.com/willy874/figma-development#readme",
  "bugs": {
    "url": "https://github.com/willy874/figma-development/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "figma",
    "cli",
    "react",
    "ui",
    "mui",
    "vite"
  ],
  "author": "willy874",
  "license": "ISC",
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "@mui/material": ">=7",
    "react": ">=18.2",
    "react-dom": ">=18.2"
  },
  "devDependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^7.0.0",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.3",
    "oxfmt": "^0.42.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.3.3",
    "typescript": "^6.0.2",
    "vite": "^8",
    "vite-plugin-dts": "^4.5.4"
  }
}
